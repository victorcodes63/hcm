# Imara — SACCO beachhead demo (Phase 1 wedge: People + Time + Payroll)
# Apply: npm run demo:reseed:imara-sacco

DEMO_PACK=imara-sacco
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Product identity (Imara Vertical BMS)
NEXT_PUBLIC_APP_NAME="Imara"
NEXT_PUBLIC_ORG_NAME="Nyati SACCO Society Ltd"
NEXT_PUBLIC_APP_TAGLINE="The operating system for regulated East African organisations — M-Pesa-native payroll, SASRA-ready."
NEXT_PUBLIC_BRAND_LOGO="/brand/platform-logo.png"
NEXT_PUBLIC_BRAND_LOGO_PNG="/brand/platform-logo.png"
NEXT_PUBLIC_BRAND_WORDMARK="Imara"
NEXT_PUBLIC_RECRUITMENT_EMPLOYER_NAME="Nyati SACCO Society Ltd"
NEXT_PUBLIC_SITE_URL="https://hcm.raventechgroup.com"

# Demo login (matches imara-sacco pack seed)
STAFF_ALLOWED_DOMAIN="nyati.demo.imara.co.ke,demo.imara.co.ke,example.com"
NEXT_PUBLIC_DEMO_ADMIN_EMAIL="demo@nyati.demo.imara.co.ke"
NEXT_PUBLIC_DEMO_HR_EMAIL="hr.demo@nyati.demo.imara.co.ke"
NEXT_PUBLIC_DEMO_FINANCE_EMAIL="finance.demo@nyati.demo.imara.co.ke"
NEXT_PUBLIC_DEMO_ESS_EMAIL="employee@nyati.demo.imara.co.ke"
NEXT_PUBLIC_DEMO_PASSWORD="Demo@2026!"
STAFF_PASSWORD="Demo@2026!"

# Phase 1 wedge — core people, time, payroll (roadmap §4)
MODULE_ATS=false
MODULE_ACCOUNTS=false
MODULE_PERFORMANCE=false
MODULE_HSE=false
MODULE_ASSETS=false

# Phase 2+ modules remain available for expansion demos when enabled
# MODULE_ATS=true
# MODULE_ACCOUNTS=true
