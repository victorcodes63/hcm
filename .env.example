# Database – PostgreSQL (required for ATS)
# Recommended: Neon (neon.tech) or Vercel Postgres – free tier for dev/preview, low cost + minimal maintenance for production.
# Neon URL example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Leave unset to use in-memory fallback (dev only; data is lost on restart).
DATABASE_URL="postgresql://user:password@localhost:5432/eagle_hr_ats?schema=public"

# SMTP – contact form + applicant emails (application received, status updates, etc.)
# Use recruitment@eaglehr.co.ke so applicants see a consistent sender.
#
# Option A – Microsoft 365 (recommended if you use Outlook/Office 365):
# SMTP_HOST="smtp.office365.com"
# SMTP_PORT="587"
# SMTP_USER="recruitment@eaglehr.co.ke"
# SMTP_PASS="your_app_password"
# (Create an app password in Microsoft 365: Account → Security → App passwords.)
#
# Option B – Your own mail server (e.g. mail.eaglehr.co.ke):
# SMTP_HOST="mail.eaglehr.co.ke"
# SMTP_PORT="465"
# SMTP_USER="recruitment@eaglehr.co.ke"
# SMTP_PASS="your_email_password"
#
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="recruitment@eaglehr.co.ke"
SMTP_PASS=""
# Display name shown as sender (e.g. "Eagle HR Recruitment"). If unset or empty, defaults to "Eagle HR Recruitment".
# Set this in production (e.g. Vercel env) so the From name is correct; otherwise some hosts may show only "recruitment".
# SMTP_FROM_NAME="Eagle HR Recruitment"
# Optional: full URL of your live site (for logo in emails). Defaults to https://www.eaglehr.co.ke or Vercel URL.
# NEXT_PUBLIC_SITE_URL="https://www.eaglehr.co.ke"

# Staff dashboard auth – required in production for /dashboard
# In development, if unset, you can sign in with password "eaglehr" (any email)
STAFF_PASSWORD="your_secure_password"
# Restrict staff sign-in to this email domain (applies to password and Microsoft sign-in)
STAFF_ALLOWED_DOMAIN="eaglehr.co.ke"
# Optional: staff session duration in days (rolling refresh on activity)
# STAFF_SESSION_DAYS="7"
# Optional: restrict login to one email (leave unset to allow any email)
# STAFF_EMAIL="staff@eaglehr.co.ke"

# Microsoft OAuth (optional, for "Sign in with Microsoft" on staff login)
# Create an app registration in Entra ID and add redirect URI:
# http://localhost:3000/api/auth/microsoft/callback (dev)
# https://your-domain/api/auth/microsoft/callback (prod)
# MS_TENANT_ID="your-tenant-id"
# MS_CLIENT_ID="your-app-client-id"
# MS_CLIENT_SECRET="your-app-client-secret"
# Optional if you want to override callback URL directly:
# MS_REDIRECT_URI="http://localhost:3000/api/auth/microsoft/callback"
# Optional: set true only when troubleshooting OAuth
# MS_OAUTH_DEBUG="false"
#
# Microsoft Graph Mail (recommended on Vercel, avoids SMTP timeout issues)
# In Entra app registration -> API permissions:
# - Add APPLICATION permission: Mail.Send
# - Click "Grant admin consent"
# Mail is sent through this mailbox:
# MS_GRAPH_MAILBOX="recruitment@eaglehr.co.ke"

# Optional monitoring webhook for API failure alerts (Slack/Teams/webhook receiver)
# MONITORING_WEBHOOK_URL="https://hooks.slack.com/services/xxx/yyy/zzz"

# Optional smoke test vars (used by npm run smoke:test)
# SMOKE_BASE_URL="http://localhost:3000"
# SMOKE_LOGIN_EMAIL="vchumo@eaglehr.co.ke"
# SMOKE_LOGIN_PASSWORD="eaglehr"
# SMOKE_APPLICATION_EMAIL="vichumo38+smoke@gmail.com"

# Optional – ATS external API (if you use an external ATS later)
# NEXT_PUBLIC_ATS_API_URL=
# NEXT_PUBLIC_ATS_API_KEY=
